[user]
  email = maclong9@icloud.com
  name = Mac

[alias]
  a = add
  aa = add .
  ac = "!f() { git add $1 && git commit -m \"$2\"; }; f"
  aac = "!f() { git add . && git commit -m \"$1\"; }; f"
  as = config --get-regexp ^alias
  b = branch
  bd = branch -d
  br = "!f() { git branch -m $1; }; f"
  c = commit -m
  ca = "!f() { git commit --amend -m \"$1\"; }; f"
  co = checkout
  col = checkout -
  d = diff
  ds = diff --stat HEAD~
  f = fetch
  l = log --oneline --decorate --all
  lg = log --graph --oneline --decorate --all
  p = push
  pl = pull
  plr = pull --rebase
  pln = pull --no-rebase
  s = status
  sh = show
  st = stash push -u
  sr = stash pop
  u = reset --soft HEAD~1

[core]
  editor = vim
  excludeFile = $HOME/.gitignore

[merge]
  tool = vimdiff

[push]
  autoSetupRemote = true
