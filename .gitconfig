[user]
  email = maclong9@icloud.com
  name = Mac

[alias]
  a = add
  aa = add .
  ac = "!f() { git add $1 && git commit -m \"$2\"; }; f"
  aac = "!f() { git add . && git commit -m \"$1\"; }; f"
  b = branch
  bd = branch -d
  br = "!f() { git branch -m $1; }; f"
  c = commit -m
  ca = "!f() { git commit --amend -m \"$1\"; }; f"
  cl = "!f() { base_url=\"https://github.com/\"; if [[ \"$1\" == *\"/\"* ]]; then git clone \"$base_url/$1.git\"; else git clone \"$base_url/maclong9/$1.git\"; fi; }; f"
  co = checkout
  col = checkout -
  d = diff
  ds = diff --stat HEAD~
  f = fetch
  l = log --oneline --decorate --all
  lg = log --graph --oneline --decorate --all
  p = push
  pl = pull
  plr = pull --rebase
  pln = pull --no-rebase
  s = status
  sh = show
  st = stash push -u
  sr = stash pop
  u = reset HEAD~1 --soft

[core]
  pager = delta
  excludeFile = $HOME/.gitignore

[delta]
  line-numbers = true
  side-by-side = true

[init]
  defaultBranch = main

[merge]
  tool = vimdiff

[pager]
  blame  = delta
  diff   = delta
  reflog = delta
  show   = delta

[push]
  autoSetupRemote = true
