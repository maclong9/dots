[user]
  email = maclong9@icloud.com
  name = Mac

[alias]
  a = add
  aa = add .
  ac = "!f() { git add . && git commit -sm \"$1\"; }; f"
  b = branch
  bb = checkout -
  bd = branch -d
  c = commit -m
  cl = "!f() { base_url=\"https://github.com/\"; if [[ \"$1\" == *\"/\"* ]]; then git clone \"$base_url/$1.git\"; else git clone \"$base_url/maclong9/$1.git\"; fi; }; f"
  co = checkout
  d = diff
  ds = diff --stat HEAD~
  l = log --oneline --decorate --all
  lg = log --graph --oneline --decorate --all
  p = push
  pl = pull
  plr = pull --rebase
  pln = pull --no-rebase
  s = status
  sh = show
  st = stash push -u
  sr = stash pop
  u = reset HEAD~1 --soft

[core]
  pager = delta

[delta]
  line-numbers = true
  side-by-side = true

[merge]
  tool = vimdiff

[push]
  autoSetupRemote = true
