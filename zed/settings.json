{
  "assistant_panel": {
    "dock": "right",
    "default_width": 300
  },
  "auto_install_extensions": {
    "anysphere-theme": true,
    "colored-zed-icons-theme": true,
    "csv": true,
    "deno": true,
    "docker-compose": true,
    "emmet": true,
    "graphql": true,
    "html": true,
    "proto": true,
    "react-typescript-snippets": true,
    "swift": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 3000
    }
  },
  "buffer_font_family": "SF Mono",
  "buffer_font_size": 12,
  "collaboration_panel": {
    "button": false
  },
  "git_panel": {
    "dock": "left",
    "default_width": 300
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "languages": {
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll": true,
        "source.organizeImports": true
      }
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll": true,
        "source.organizeImports": true
      }
    }
  },
  "notification_panel": {
    "button": false
  },
  "outline_panel": {
    "default_width": 300,
    "dock": "right"
  },
  "project_panel": {
    "default_width": 300,
    "dock": "left"
  },
  "relative_line_numbers": true,
  "terminal": {
    "button": false
  },
  "theme": {
    "dark": "Anysphere Theme",
    "light": "One Light",
    "mode": "system"
  },
  "ui_font_family": "SF Pro",
  "ui_font_size": 12,
  "vim_mode": true
}
