{
  "agent": {
    "model_parameters": [],
    "always_allow_tool_actions": true,
    "version": "2"
  },
  "auto_install_extensions": {
    "anysphere-theme": true,
    "colored-zed-icons-theme": true,
    "csv": true,
    "deno": true,
    "docker-compose": true,
    "emmet": true,
    "git-firefly": true,
    "html": true,
    "package-swift-lsp": true,
    "proto": true,
    "react-typescript-snippets": true,
    "swift": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 3000
    }
  },
  "buffer_font_family": "SF Mono",
  "buffer_font_features": {
    "calt": true
  },
  "buffer_font_size": 11,
  "code_actions_on_format": {
    "source.fixall": true,
    "source.organizeImports": true
  },
  "collaboration_panel": {
    "default_width": 300
  },
  "chat_panel": {
    "default_width": 300,
    "dock": "left"
  },
  "git_panel": {
    "default_width": 300,
    "dock": "left"
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "outline_panel": {
    "default_width": 300,
    "dock": "right"
  },
  "project_panel": {
    "default_width": 300,
    "dock": "left",
    "hide_gitignore": true
  },
  "relative_line_numbers": true,
  "terminal": {
    "button": false,
    "default_height": 360
  },
  "theme": {
    "dark": "Anysphere Theme",
    "light": "One Light",
    "mode": "system"
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_user_picture": false
  },
  "ui_font_family": "SF Pro",
  "ui_font_size": 11,
  "vim_mode": true
}
